{
  "schemaVersion": 1,

  "loop": {
    "tickHz": 60,
    "maxStepsPerFrame": 6,
    "maxFrameGapMs": 250,
    "interpolate": true
  },

  "view": {
    "logicalW": 1280,
    "logicalH": 720,
    "arena": { "x": 350, "y": 0, "w": 580, "h": 720 },
    "panelLeftW": 350,
    "panelRightW": 350,
    "bandTopH": 48,
    "bandHpH": 24,
    "bandXpH": 24,
    "playerBoundsInset": { "top": 56, "bottom": 56, "left": 20, "right": 20 },
    "spawnLineY": -40,
    "minViewportW": 1024,
    "minViewportH": 576,
    "maxDpr": 2
  },

  "collide": {
    "gridCellPx": 64
  },

  "caps": {
    "playerBullets": 256,
    "enemyBullets": 384,
    "enemies": 96,
    "pickups": 256,
    "zones": 64,
    "drones": 8,
    "particles": 400,
    "telegraphs": 96,
    "damageNumbers": 10,
    "effectMarkers": 12,
    "overflow": {
      "playerBullet": "rejectSpawn",
      "enemyBullet": "rejectSpawn",
      "enemy": "defer",
      "pickup": "merge",
      "zone": "rejectSpawn",
      "drone": "rejectSpawn",
      "telegraph": "deferAttack",
      "particle": "evictOldest",
      "damageNumber": "evictOldest",
      "effectMarker": "evictOldest"
    }
  },

  "player": {
    "hpMax": 100,
    "spriteRadius": 14,
    "hitboxRadius": 4,
    "moveSpeed": 280,
    "moveResponseTau": 0.0,
    "diagonalNormalize": true,
    "iframeSec": 1.0,
    "defenseBase": 0,
    "damageFloorRatio": 0.25,
    "lowHpThreshold": 0.30,
    "lowHpCriticalThreshold": 0.15,
    "magnetRadius": 90,
    "healPickupPct": 0.35,
    "startWeaponId": "forward",
    "startStance": "normal",
    "stanceSwitchCooldown": 0.0,
    "stancePersistAcrossStages": true,
    "elementCapPerElement": 4,
    "elementCapTotal": 6,
    "weaponSlots": 4,
    "passiveSlots": 6,
    "lives": 0
  },

  "status": {
    "slowMoveSpeedMul": 0.55,
    "stackMode": "refresh",
    "resistAffects": "duration"
  },

  "bomb": {
    "stockStart": 1,
    "stockMax": 3,
    "iframeSec": 1.5,
    "mobDmg": 9999,
    "clearsEnemyBullets": true,
    "clearsDuringBoss": true,
    "bossDmgRatio": 0.04,
    "bossDmgCap": 220
  },

  "elite": {
    "perWaveMax": 1,
    "hpMult": 4.0,
    "sizeMult": 1.4,
    "contactDmgMul": 1.5,
    "xpMult": 6.0,
    "coin": 3,
    "healDropChance": 0.12,
    "bandAllowed": ["line", "turret", "bruiser"],
    "elementAllowed": ["fire", "water", "grass"]
  },

  "boss": {
    "partCount": 4,
    "partRegen": false,
    "summonsAllowed": false,
    "partHitPriority": "outermostFirst",
    "phaseThresholds": [0.6, 0.3],
    "phaseTransitionSec": 1.5,
    "timerPausesOnPhaseTransition": true,
    "introSec": 3.0,
    "timerStartsAfterIntro": true,
    "timerExpire": "kill",
    "coreGateMul": 0.4,
    "mobilityPenalty": 0.5,
    "coreElement": "normal",
    "partNormalForbidden": true,
    "partElementDistinctMin": 2,
    "partThemeElementMax": 1,
    "armorElementNotTheme": true,
    "armorPartCountRange": [2, 2],
    "armorCoreRatioBandPct": [0.85, 1.0],
    "coin": 12,
    "partCoin": 2,
    "optionalPartArmorRatio": 0.20,
    "midBossSummonsAllowed": ["mbNest"],
    "finale": {
      "partCount": 5,
      "armorPartCount": 3,
      "exemptRules": ["R4", "R6"],
      "allowNormalPeripheral": true
    }
  },

  "fairness": {
    "minTelegraphSec": 0.55,
    "minStunTelegraphSec": 1.5,
    "maxStunSec": 1.0,
    "maxBulletSpeed": 260,
    "maxAimedBulletSpeed": 200,
    "statusBulletSpeedMul": 0.6,
    "minBulletRadiusPx": 4,
    "minGapWidthPx": 46,
    "minSpawnRadiusPx": 140,
    "maxSimultaneousEnemyBullets": 320,
    "enemyConcurrentMax": 40,
    "swarmConcurrentMax": 70,
    "crisisWaveResidualMax": 10,
    "telegraphConcurrentMaxPerEntity": 2,
    "telegraphConcurrentMaxGlobal": 80,
    "playerWeaponsExempt": true
  },

  "hud": {
    "hitboxAlwaysVisible": true,
    "showElementBudget": true,
    "fontHeroPx": 40,
    "fontLargePx": 26,
    "fontMediumPx": 20,
    "fontBodyPx": 16,
    "fontSmallPx": 14,
    "panelPadPx": 16,
    "keycapBoxPx": 28,
    "bossHpBarH": 8,
    "hpBarSegGapPx": 5,
    "xpBarH": 6,
    "hpBarSegCount": 5,
    "panelCacheDirtyOnly": true,
    "parGhostEnabled": true,
    "elementMatrixInPanel": true,
    "coinShowsScoreValue": true,
    "noHitIndicator": true,
    "tokenKeycapGatedDisplay": true,
    "stanceHintTargetsMajorityElement": true,
    "icons": ["coinDisc", "xpDiamond", "bombRound", "shieldHex", "tokenClock",
              "rerollArrows", "statusSlow", "statusStun", "resistShield",
              "potionFlask", "defenseChevron", "hpCross", "bootWing", "magnetHorseshoe"]
  },

  "passiveHooks": {
    "forward":   { "rateKey": "cooldownSec",      "countKey": "count",            "pierceApplies": true,  "areaKeys": ["projRadius"] },
    "fan":       { "rateKey": "cooldownSec",      "countKey": "count",            "pierceApplies": true,  "areaKeys": ["projRadius", "evoBlastRadius"] },
    "seeker":    { "rateKey": "cooldownSec",      "countKey": "count",            "pierceApplies": true,  "areaKeys": ["projRadius", "acquireRadius"] },
    "lance":     { "rateKey": "cooldownSec",      "countKey": "count",            "pierceApplies": true,  "areaKeys": ["beamWidthPx", "rangePx"] },
    "orbit":     { "rateKey": "hitCooldownSec",   "countKey": "bodyCount",        "pierceApplies": false, "areaKeys": ["orbitRadius", "projRadius"] },
    "aura":      { "rateKey": "tickIntervalSec",  "countKey": null,               "pierceApplies": false, "areaKeys": ["radius"] },
    "mine":      { "rateKey": "placeIntervalSec", "countKey": "maxAlive",         "pierceApplies": false, "areaKeys": ["blastRadius", "triggerRadius", "evoClusterRadius"] },
    "boomerang": { "rateKey": "cooldownSec",      "countKey": "count",            "pierceApplies": false, "areaKeys": ["outRangePx", "projRadius"] },
    "barrage":   { "rateKey": "cooldownSec",      "countKey": "strikesPerVolley", "pierceApplies": false, "areaKeys": ["blastRadius"] },
    "omni":      { "rateKey": "cooldownSec",      "countKey": "dirCount",         "pierceApplies": true,  "areaKeys": ["projRadius"] },
    "drone":     { "rateKey": "droneFireSec",     "countKey": null,               "pierceApplies": true,  "areaKeys": ["droneRangePx", "projRadius"] },
    "nova":      { "rateKey": "intervalSec",      "countKey": null,               "pierceApplies": false, "areaKeys": ["radius", "evoRing2Radius"] }
  },

  "input": {
    "layout": "code",
    "socd": "lastInput",
    "pauseOnBlur": true,
    "bindings": {
      "move": ["ArrowLeft", "ArrowUp", "ArrowRight", "ArrowDown"],
      "stanceNormal": "KeyQ",
      "stanceFire": "KeyW",
      "stanceWater": "KeyE",
      "stanceGrass": "KeyR",
      "bomb": "Space",
      "timeToken": "ShiftLeft",
      "pause": "Escape",
      "options": "KeyO",
      "draftPick": ["Digit1", "Digit2", "Digit3"],
      "reroll": "KeyF",
      "reorderToggle": "Tab",
      "grab": "Space",
      "confirm": "Enter",
      "cursor": ["ArrowLeft", "ArrowRight", "ArrowUp", "ArrowDown"]
    }
  },

  "palette": {
    "element":    { "normal": "#DCE6F0", "fire": "#FF6B2C", "water": "#31C0FF", "grass": "#5FD13B" },
    "elementCvd": { "normal": "#F2F6FA", "fire": "#FFA83A", "water": "#2E86E0", "grass": "#1F6B3A" },
    "threat":     { "enemyBullet": "#FF2E88", "telegraph": "#FF2E88", "bulletCore": "#FFFFFF", "outline": "#0A0C10" },
    "status":     { "band": "#FFB000" },
    "pickup":     { "coin": "#FFC93C", "xp": "#EAF2FF" },
    "enemyBody": "#20242C",
    "partDestroyed": "#3A3A3A",
    "neutralGray": "#7A8290",
    "hud": {
      "panelBg": "#0E1116",
      "panelRule": "#2A3038",
      "textPrimary": "#DCE6F0",
      "textDim": "#7A8290",
      "hpFill": "#DCE6F0"
    },
    "bg": {
      "maxSaturation": 0.25,
      "maxLightness": 0.28,
      "cvdMaxLightness": 0.22,
      "parallaxLayers": 2,
      "maxScrollSpeed": 90
    }
  },

  "visual": {
    "iframeBlinkHz": 8.0,
    "stance": {
      "ringExpandSec": 0.18,
      "ringMaxRadiusPx": 28,
      "ringStrokePx": 2,
      "emptyDesatSec": 0.18,
      "dotRadiusPx": 4,
      "dotRingPx": 2,
      "auraAlpha": 0.40,
      "pipPx": 7,
      "pipPxCvd": 10,
      "pipGapPx": 2,
      "pipOffsetYPx": 14,
      "hintPulseHz": 1.0,
      "hintPulseAlpha": [0.40, 1.0]
    },
    "playerBullet": {
      "coreRadiusRatio": 0.45,
      "coreLightnessAdd": 25
    },
    "glyph": {
      "bodyRatio": 0.42,
      "maxPx": 22,
      "occludedSkip": true,
      "lodMinBodyPx": 16,
      "lodDegradedBodyPx": 24
    },
    "telegraph": {
      "strokePx": 2,
      "dashPx": 6,
      "dashTightenAtPct": 0.70,
      "dashTightenMul": 0.5,
      "airAlpha": 0.50,
      "fillAlpha": 0.50,
      "emphasisBySpeed": { "1.0": 1.0, "1.5": 1.15, "2.0": 1.30, "3.0": 1.50 }
    },
    "band": {
      "plateAlpha": 0.30,
      "contentOpaque": true
    },
    "zone": {
      "fillAlpha": 0.30,
      "pulseHz": 1.0
    },
    "timer": {
      "warnScale": 1.15,
      "warnPulseHz": 0.5,
      "alertScale": 1.30,
      "alertPulseHz": 1.0
    },
    "trail": {
      "ghostCount": 3,
      "ghostAlpha": 0.30
    },
    "hitFx": {
      "numberTargets": ["boss", "midboss", "elite"],
      "numberAggregateSec": 0.15,
      "numberMinPx": 14,
      "numberOutlinePx": 2,
      "numberLifeSec": 0.7,
      "numberDriftPx": 18,
      "markerPolicy": "maxOnly",
      "markerCooldownSecPerEntity": 0.25,
      "superFreezeSec": 0.04,
      "superFreezeScale": 1.12,
      "resistArcSweepDeg": 160,
      "resistArcLifeSec": 0.25,
      "resistArcStrokePx": 4,
      "particles": { "super": 3, "neutral": 1, "resist": 0 }
    },
    "a11y": {
      "cbMode": "off",
      "reduceFlash": false,
      "screenShake": true,
      "shakeMaxPx": 6,
      "fullscreenFlashMaxPerSec": 3,
      "fullscreenFlashMaxAlpha": 0.35
    },
    "text": {
      "family": "system-ui, -apple-system, 'Malgun Gothic', sans-serif",
      "minPx": 14,
      "outlinePx": 2
    }
  },

  "render": {
    "playerFxCompositeAlpha": 0.45,
    "killFxCompositeAlpha": 0.55,
    "playerBulletMaxAlpha": 0.80,
    "playerBulletMaxRadiusPx": 10,
    "particleMaxAlpha": 0.60,
    "particleMaxLifeSec": 0.35,
    "fxMinRealMs": 50,
    "targetFps": 60,
    "degradeOnFrameMs": 14.0,
    "degradeRecoverFrames": 120
  },

  "audio": {
    "busGain": { "sfx": 0.8 },
    "cueRateLimitPerSec": 12
  }
}
